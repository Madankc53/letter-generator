<!DOCTYPE html>
<html lang="ne">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ऋण आवेदन निवेदन पत्र | Loan Application Letter Nepal</title>
  <meta name="description" content="नेपालमा बैंकमा ऋण आवेदन गर्नको लागि तयार निवेदन पत्र। व्यक्तिगत, व्यापार, घर, कृषि ऋणको लागि।"/>
  <meta name="keywords" content="loan application letter nepal, ऋण आवेदन पत्र नेपाल, bank loan letter nepal"/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://letter.madankc.com.np/letter-for-bank/loan-application.html"/>
  <link href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Nepal&family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/components/letter.css"/>
</head>
<body>
<div id="site-header"></div>
<div class="page-hero">
  <div class="breadcrumb"><a href="/">गृहपृष्ठ</a> › <a href="/letter-for-bank/bank-letters.html">बैंक पत्र</a> › ऋण आवेदन पत्र</div>
  <h1>💰 ऋण आवेदन निवेदन पत्र</h1>
  <p>Loan Application Letter — Nepal</p>
</div>
<div class="container">
  <div class="ad-slot">📢 Advertisement</div>
  <div class="info-box"><strong>📌 कसरी प्रयोग गर्ने?</strong><br/>ऋणको प्रकार र विवरण भर्नुहोस् → पत्र बनाउनुहोस् → प्रिन्ट गर्नुहोस्।</div>
  <div class="form-card">
    <div class="form-section-title">📝 विवरण भर्नुहोस्</div>
    <div class="form-grid">
      <div class="form-group"><label>पूरा नाम * | Full Name</label><input type="text" id="full_name" placeholder="राम बहादुर श्रेष्ठ"/></div>
      <div class="form-group"><label>बाबुको नाम | Father's Name</label><input type="text" id="father_name" placeholder="हरि बहादुर श्रेष्ठ"/></div>
      <div class="form-group"><label>बैंकको नाम * | Bank Name</label><input type="text" id="bank_name" placeholder="नबिल बैंक लि."/></div>
      <div class="form-group"><label>शाखा | Branch</label><input type="text" id="branch_name" placeholder="दमौली शाखा"/></div>
      <div class="form-group"><label>ऋणको प्रकार * | Loan Type</label>
        <select id="loan_type">
          <option value="व्यक्तिगत ऋण">व्यक्तिगत ऋण (Personal Loan)</option>
          <option value="व्यापार ऋण">व्यापार ऋण (Business Loan)</option>
          <option value="घर कर्जा">घर कर्जा (Home Loan)</option>
          <option value="कृषि ऋण">कृषि ऋण (Agriculture Loan)</option>
          <option value="शिक्षा ऋण">शिक्षा ऋण (Education Loan)</option>
          <option value="वाहन ऋण">वाहन ऋण (Vehicle Loan)</option>
        </select>
      </div>
      <div class="form-group"><label>ऋणको रकम * | Loan Amount</label><input type="text" id="loan_amount" placeholder="रु. ५,००,०००"/></div>
      <div class="form-group"><label>ऋणको उद्देश्य * | Purpose</label><input type="text" id="loan_purpose" placeholder="व्यवसाय विस्तारको लागि"/></div>
      <div class="form-group"><label>ठेगाना * | Address</label><input type="text" id="address" placeholder="शुक्लागण्डकी-३, तनहुँ"/></div>
      <div class="form-group"><label>नागरिकता नम्बर | Citizenship No.</label><input type="text" id="citizenship_no" placeholder="XX-XX-XXXXXXX"/></div>
      <div class="form-group"><label>सम्पर्क नम्बर | Phone</label><input type="tel" id="phone" placeholder="९८XXXXXXXX"/></div>
      <div class="form-group"><label>धितो/जमानत | Collateral</label><input type="text" id="collateral" placeholder="जग्गाजमिन, घर..."/></div>
      <div class="form-group"><label>मिति | Date</label><input type="date" id="date"/></div>
    </div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="resetForm()">🔄 Reset</button>
      <button class="btn btn-primary" onclick="generateLetter()">📄 पत्र बनाउनुहोस्</button>
    </div>
  </div>
  <div class="ad-slot">📢 Advertisement</div>
</div>
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✅ पत्र तयार छ!</div>
      <div class="modal-actions">
        <button class="btn btn-secondary btn-sm" onclick="closeModal()">✖ बन्द</button>
        <button class="btn btn-primary btn-sm" onclick="window.print()">🖨️ Print</button>
      </div>
    </div>
    <div class="modal-body"><div class="letter-doc" id="letterDoc"></div></div>
  </div>
</div>
<div id="site-footer"></div>
<div class="toast" id="toast"></div>
<script src="/components/loader.js"></script>
<script src="/components/letter.js"></script>
<script>
document.getElementById('date').valueAsDate = new Date();
function generateLetter() {
  const name = document.getElementById('full_name').value.trim();
  const father = document.getElementById('father_name').value.trim();
  const bank = document.getElementById('bank_name').value.trim();
  const branch = document.getElementById('branch_name').value.trim();
  const loanType = document.getElementById('loan_type').value;
  const amount = document.getElementById('loan_amount').value.trim();
  const purpose = document.getElementById('loan_purpose').value.trim();
  const address = document.getElementById('address').value.trim();
  const cit = document.getElementById('citizenship_no').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const collateral = document.getElementById('collateral').value.trim();
  const dateStr = getDate();
  if (!name) { showToast('❌ नाम अनिवार्य छ!', 'error'); return; }
  if (!bank) { showToast('❌ बैंकको नाम अनिवार्य छ!', 'error'); return; }
  if (!amount) { showToast('❌ ऋणको रकम अनिवार्य छ!', 'error'); return; }
  if (!purpose) { showToast('❌ ऋणको उद्देश्य अनिवार्य छ!', 'error'); return; }
  const html = `
    <p class="right">मिति: ${dateStr}</p><br/>
    <p><strong>श्रीमान् शाखा प्रबन्धक महोदय,</strong></p>
    <p>${bank}${branch ? ', ' + branch : ''},</p>
    <p>${address}</p><br/>
    <p><strong>विषय: ${loanType} प्रदान गर्ने सम्बन्धमा ।</strong></p><br/>
    <p>महोदय,</p>
    <p>म <strong>${name}</strong>${father ? ', श्री ' + father + 'का छोरा/छोरी,' : ','} ${address} बासिन्दाले <strong>${purpose}</strong> को लागि <strong>${amount}</strong> को ${loanType} आवश्यक परेकोले यो निवेदन पेश गरेको छु ।</p>
    <p>${collateral ? 'धितोको रूपमा <strong>' + collateral + '</strong> राख्न तयार छु ।' : ''} आवश्यक कागजातहरू संलग्न गरेको छु । कृपया ऋण स्वीकृत गरिदिनुहुन हार्दिक अनुरोध गर्दछु ।</p>
    <br/><br/>
    <p>निवेदक,</p><br/><br/>
    <p>..............................</p>
    <p><strong>${name}</strong></p>
    <p>${address}</p>
    ${cit ? '<p>ना.प्र.नं.: ' + cit + '</p>' : ''}
    ${phone ? '<p>सम्पर्क: ' + phone + '</p>' : ''}
  `;
  showLetter(html);
}
</script>
</body>
</html>
